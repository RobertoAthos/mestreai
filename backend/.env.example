# OpenRouter API key — placeholder until real key is provided
OPENROUTER_API_KEY=mock-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# App config
APP_NAME=Mestre IA
ENVIRONMENT=development
STORAGE_PATH=./storage
MAX_PDF_SIZE_MB=25

# Mock mode — when true, the backend returns canned AI responses
# instead of calling OpenRouter. Set to false once you add a real key.
MOCK_AI=true

# Postgres — asyncpg driver.
#
# IMPORTANT: this DATABASE_URL is used ONLY when you run uvicorn directly
# on your host machine (bare-metal). When you run `docker compose up`,
# the compose file hardcodes the in-network URL `postgres://...@db:5432/...`
# and ignores this value — the `db` host only resolves inside the compose
# network.
#
# For the cloud, paste the full managed Postgres connection string here
# (and remove the docker-compose hardcode if you want compose to talk to
# the cloud DB instead of the local one).
DATABASE_URL=postgresql+asyncpg://mestreai:mestreai@localhost:5432/mestreai
DB_ECHO=false

# Used by docker-compose to bring up the local Postgres service. The
# `db` service applies these as POSTGRES_USER/PASSWORD/DB, and the `api`
# service uses them to build the in-network DATABASE_URL.
POSTGRES_USER=mestreai
POSTGRES_PASSWORD=mestreai
POSTGRES_DB=mestreai
POSTGRES_PORT=5432
